#!/usr/bin/env bash
set -euo pipefail

function in_tmux_passthrough() {
    [[ -n "${TMUX:-}" || "${TERM:-}" == screen* || "${TERM:-}" == tmux* ]]
}

function print_osc() {
    if in_tmux_passthrough; then
        printf '\033Ptmux;\033\033]'
    else
        printf '\033]'
    fi
}

function print_st() {
    if in_tmux_passthrough; then
        printf '\a\033\\'
    else
        printf '\a'
    fi
}

function error() {
    echo "ERROR: $*" >&2
}

function show_help() {
    echo "Usage: imgcat [-p] filename ..." >&2
    echo "   or: cat filename | imgcat" >&2
}

function check_dependency() {
    if ! command -v "$1" >/dev/null 2>&1; then
        error "missing dependency: can't find $1"
        exit 1
    fi
}

function b64_encode_file() {
    base64 < "$1" | tr -d '\n'
}

function b64_encode_stdin() {
    base64 | tr -d '\n'
}

function b64_decode_count_bytes() {
    local encoded="$1"
    printf "%s" "$encoded" | base64 -d 2>/dev/null | wc -c | awk '{printf "%d", $1}'
}

function pdf_to_jpg_base64() {
    local pdf="$1"
    local tmpdir jpg outbase

    tmpdir="$(mktemp -d)"
    outbase="$tmpdir/page"
    jpg="$outbase.jpg"

    if command -v pdftoppm >/dev/null 2>&1; then
        pdftoppm -jpeg -singlefile -f 1 -l 1 -r 200 "$pdf" "$outbase" >/dev/null 2>&1
    elif command -v convert >/dev/null 2>&1; then
        convert -density 200 "$pdf[0]" -quality 90 "$jpg" >/dev/null 2>&1
    else
        rm -rf "$tmpdir"
        error "PDF support needs pdftoppm from poppler-utils or ImageMagick convert"
        return 1
    fi

    if [[ ! -s "$jpg" ]]; then
        rm -rf "$tmpdir"
        return 1
    fi

    b64_encode_file "$jpg"
    rm -rf "$tmpdir"
}

function print_image() {
    local filename="$1"
    local inline="$2"
    local encoded="$3"
    local print_filename="${4:-}"
    local size

    size="$(b64_decode_count_bytes "$encoded")"

    print_osc
    printf '1337;File='

    if [[ -n "$filename" ]]; then
        printf 'name=%s;' "$(printf "%s" "$filename" | base64 | tr -d '\n')"
    fi

    printf 'size=%s;inline=%s:' "$size" "$inline"
    printf "%s" "$encoded"
    print_st
    printf '\n'

    if [[ -n "$print_filename" ]]; then
        echo "$filename"
    fi
}

function is_pdf() {
    local file="$1"

    case "$file" in
        *.pdf|*.PDF)
            return 0
            ;;
    esac

    if command -v file >/dev/null 2>&1; then
        file --mime-type -b "$file" 2>/dev/null | grep -qi '^application/pdf$'
    else
        return 1
    fi
}

function print_file() {
    local file="$1"
    local encoded display_name

    if is_pdf "$file"; then
        encoded="$(pdf_to_jpg_base64 "$file")" || {
            error "Failed to convert PDF: $file"
            exit 2
        }
        display_name="${file%.*}.jpg"
        print_image "$display_name" 1 "$encoded" "${print_filename:-}"
    else
        encoded="$(b64_encode_file "$file")"
        print_image "$file" 1 "$encoded" "${print_filename:-}"
    fi
}

has_stdin=f
if [[ ! -t 0 ]]; then
    has_stdin=t
fi

if [[ "$has_stdin" == f && $# -eq 0 ]]; then
    show_help
    exit 0
fi

check_dependency awk
check_dependency base64
check_dependency wc

print_filename=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--h|--help)
            show_help
            exit 0
            ;;
        -p|--p|--print)
            print_filename=1
            ;;
        -u|--u|--url)
            check_dependency curl
            if [[ $# -lt 2 ]]; then
                error "missing URL after $1"
                exit 1
            fi
            encoded_image="$(curl -fsSL "$2" | b64_encode_stdin)" || {
                error "No such file or URL: $2"
                exit 2
            }
            has_stdin=f
            print_image "$2" 1 "$encoded_image" "$print_filename"
            shift
            ;;
        -*)
            error "Unknown option flag: $1"
            show_help
            exit 1
            ;;
        *)
            if [[ -r "$1" ]]; then
                has_stdin=f
                print_file "$1"
            else
                error "imgcat: $1: No such file or directory"
                exit 2
            fi
            ;;
    esac
    shift
done

if [[ "$has_stdin" == t ]]; then
    print_image "" 1 "$(b64_encode_stdin)" ""
fi

