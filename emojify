#!/usr/bin/env python3
"""Replace emoji aliases in ASCII stdin and write the result to stdout."""

import sys

import emoji


def main() -> int:
    text = sys.stdin.buffer.read().decode("ascii", errors="replace")
    rendered = emoji.emojize(text, language="alias")
    try:
        sys.stdout.write(rendered)
    except BrokenPipeError:
        return 0
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
