#!/usr/bin/env perl
use strict;
use warnings;
use Sys::Hostname qw(hostname);

my $host   = hostname();
my $distro = $ENV{WSL_DISTRO_NAME} // "Ubuntu";  # fallback if not in WSL

open(my $ls, "-|", "/bin/ls", @ARGV)
    or die "Failed to exec /bin/ls: $!";

while (my $line = <$ls>) {
    # Replace hostname with WSL UNC path
    $line =~ s@\Q$host\E@//wsl.localhost/$distro@g;

    # Convert /mnt/c → c:
    $line =~ s@//wsl.localhost/$distro/mnt/c@c:@g;

    print $line;
}

close($ls);

